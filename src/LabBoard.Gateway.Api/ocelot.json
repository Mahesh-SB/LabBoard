{
  "Routes": [

    // ── Auth API (/auth/{everything} → labboard-auth-api:8080/{everything}) ──
    {
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "labboard-auth-api", "Port": 8080 }
      ]
    },

    // ── Redis API (/redis/{everything} → labboard-redis-api:8080/{everything}) ──
    {
      "UpstreamPathTemplate": "/redis/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "labboard-redis-api", "Port": 8080 }
      ]
    },

    // ── TicketMaster API (/ticketmaster/{everything} → labboard-ticketmaster-api:8080/{everything}) ──
    {
      "UpstreamPathTemplate": "/ticketmaster/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "labboard-ticketmaster-api", "Port": 8080 }
      ]
    },

    // ── Observability (/observability/{everything} → labboard-observability:8080/{everything}) ──
    {
      "UpstreamPathTemplate": "/observability/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "labboard-observability", "Port": 8080 }
      ]
    },

    // ── UserManagement API (/usermanagement/{everything} → labboard-usermanagement-api:8080/{everything}) ──
    {
      "UpstreamPathTemplate": "/usermanagement/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "labboard-usermanagement-api", "Port": 8080 }
      ]
    }

  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5200"
  }
}
