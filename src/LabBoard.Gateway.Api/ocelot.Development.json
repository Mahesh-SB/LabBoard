{
  "Routes": [

    // ── Auth API (/auth/{everything} → localhost:5100/{everything}) ──
    {
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5100 }
      ]
    },

    // ── Redis API (/redis/{everything} → localhost:5000/{everything}) ──
    {
      "UpstreamPathTemplate": "/redis/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5000 }
      ]
    },

    // ── TicketMaster API (/ticketmaster/{everything} → localhost:5300/{everything}) ──
    {
      "UpstreamPathTemplate": "/ticketmaster/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5300 }
      ]
    },

    // ── Observability (/observability/{everything} → localhost:5001/{everything}) ──
    {
      "UpstreamPathTemplate": "/observability/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5001 }
      ]
    }

  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5200"
  }
}
