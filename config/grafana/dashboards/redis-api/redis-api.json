{
  "title": "LabBoard Redis Dashboard",
  "uid": "labboard-redis",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "tags": ["redis", "dotnet", "labboard"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_received_total{job=\"labboard-redis-api\"}[1m])) by (method, handler, code)",
          "legendFormat": "{{method}} {{handler}} [{{code}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "HTTP Request Duration P95 / P99 (seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"labboard-redis-api\"}[5m])) by (le, handler))",
          "legendFormat": "P95 {{handler}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"labboard-redis-api\"}[5m])) by (le, handler))",
          "legendFormat": "P99 {{handler}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Cache Hit / Miss Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(labboard_redis_cache_hits_total{job=\"labboard-redis-api\"}[1m])",
          "legendFormat": "Hits/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(labboard_redis_cache_misses_total{job=\"labboard-redis-api\"}[1m])",
          "legendFormat": "Misses/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Cache Hit Ratio (%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * rate(labboard_redis_cache_hits_total{job=\"labboard-redis-api\"}[5m]) / (rate(labboard_redis_cache_hits_total{job=\"labboard-redis-api\"}[5m]) + rate(labboard_redis_cache_misses_total{job=\"labboard-redis-api\"}[5m]))",
          "legendFormat": "Hit Ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Redis Used Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "labboard_redis_used_memory_bytes{job=\"labboard-observability\"}",
          "legendFormat": "Used Memory",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "labboard_redis_used_memory_rss_bytes{job=\"labboard-observability\"}",
          "legendFormat": "RSS Memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Redis Connected Clients",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "labboard_redis_connected_clients{job=\"labboard-observability\"}",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Redis Blocked Clients",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "labboard_redis_blocked_clients{job=\"labboard-observability\"}",
          "legendFormat": "Blocked",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Redis Keyspace Hits vs Misses",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(labboard_redis_keyspace_hits_total{job=\"labboard-observability\"}[1m])",
          "legendFormat": "Keyspace Hits/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(labboard_redis_keyspace_misses_total{job=\"labboard-observability\"}[1m])",
          "legendFormat": "Keyspace Misses/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Redis Commands Processed Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(labboard_redis_commands_processed_total{job=\"labboard-observability\"}[1m])",
          "legendFormat": "Commands/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Redis Operation Duration (API)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(labboard_redis_op_duration_seconds_bucket{job=\"labboard-redis-api\"}[5m])) by (le, operation))",
          "legendFormat": "P99 {{operation}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(labboard_redis_op_duration_seconds_bucket{job=\"labboard-redis-api\"}[5m])) by (le, operation))",
          "legendFormat": "P50 {{operation}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    }
  ]
}
